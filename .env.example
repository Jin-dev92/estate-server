# Database
DATABASE_URL="postgresql://estate:estate@localhost:5433/estate?schema=public"
# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="1h"
# 카카오 OAuth (F1) — 카카오 개발자 콘솔 앱의 REST API 키(client id)·client secret.
# 서버 전용. FE에는 NEXT_PUBLIC_KAKAO_CLIENT_ID(공개 가능)만 둔다.
KAKAO_CLIENT_ID="change-me"
KAKAO_CLIENT_SECRET="change-me"
# 카카오 호출 회복탄력성(M12) — 미설정 시 코드 기본값. 실측 전 잠정값(k6 튜닝 후속).
KAKAO_TIMEOUT_MS="3000"
KAKAO_RETRY_MAX_ATTEMPTS="3"
KAKAO_BREAKER_THRESHOLD="5"
KAKAO_BREAKER_HALF_OPEN_MS="10000"
KAKAO_BULKHEAD_CONCURRENT="10"
KAKAO_BULKHEAD_QUEUE="20"
# 프로필 재시도 전체(시도+백오프)의 벽시계 상한 — 느린 카카오의 꼬리 지연을 끊는다.
KAKAO_TOTAL_TIMEOUT_MS="8000"
# Infra (M1~)
REDIS_URL="redis://localhost:6379"
KAFKA_BROKERS="localhost:9092"
# Rate limit (M6) — 윈도우(초)당 허용 쓰기 수. userId·IP 이중 제한.
RATE_LIMIT_WINDOW_SEC="60"
RATE_LIMIT_USER_MAX="60"
RATE_LIMIT_IP_MAX="120"
# Transactional Outbox (relay 워커 폴링)
OUTBOX_POLL_MS="1000"
OUTBOX_BATCH_SIZE="100"
OUTBOX_MAX_ATTEMPTS="5"
OUTBOX_BACKOFF_BASE_MS="1000"
OUTBOX_BACKOFF_CAP_MS="60000"
# Sentry (M10) — DSN 비우면 비활성(no-op).
# ⚠️ 아래 DSN은 학습/테스트 편의를 위해 올린 무료 티어 프로젝트 키다(ingest 전용이라
#    데이터 조회·삭제 불가, 노출 시 리스크는 스팸/쿼터 소진뿐). production 배포 시에는
#    이 값을 쓰지 않고 환경변수 secret(예: GitHub Secrets·배포 파이프라인)으로 주입한다.
SENTRY_DSN="https://f57a208de59072341a5210b4060fdb26@o4511578989330432.ingest.us.sentry.io/4511578994769920"
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
# 일부 4xx(422 도메인 위반·400 검증 실패 = FE/계약 버그 신호)를 낮은 비율로 캡처.
# 기본 0(전송 안 함). 배포 직후·디버깅 때만 0.05 등으로 올린다. 사용자발 4xx(401·404)는 항상 제외.
SENTRY_4XX_SAMPLE_RATE="0"
