{
  "uid": "estate-server-db",
  "title": "Estate Server DB Performance",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "DB Transaction Rate (TPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_commit{datname=\"estate\"}[1m]))",
          "legendFormat": "commit",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_rollback{datname=\"estate\"}[1m]))",
          "legendFormat": "rollback",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Connection Saturation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_stat_database_numbackends{datname=\"estate\"})",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_settings_max_connections",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_database_blks_hit{datname=\"estate\"} / clamp_min(pg_stat_database_blks_hit{datname=\"estate\"} + pg_stat_database_blks_read{datname=\"estate\"}, 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_deadlocks{datname=\"estate\"}[5m]))",
          "legendFormat": "deadlocks/s",
          "refId": "A"
        }
      ]
    }
  ]
}
